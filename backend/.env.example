
PORT=5000
NODE_ENV=development
JWT_SECRET=coderunner_dev_secret_2024_change_me
JWT_EXPIRES_IN=7d

DB_HOST=localhost
DB_PORT=5432
DB_NAME=coderunner
DB_USER=postgres
DB_PASSWORD=postgres

REDIS_HOST=localhost
REDIS_PORT=6379
# ── IMPORTANT for distributed setup ──────────────────────────────
# Set a strong Redis password. Workers on PC-2/PC-3 use this to
# authenticate over the LAN. Must match REDIS_PASSWORD in worker .env.
REDIS_PASSWORD=change_me_strong_password

# ── Development only (no workers running remotely) ────────────────
# Worker concurrency: used only if you uncomment the fallback worker
# in docker-compose.yml (emergency local mode)
WORKER_CONCURRENCY=8
SUBMIT_CONCURRENCY=4
TC_CONCURRENCY=8

# Execution limits
MAX_EXECUTION_TIME=10000
MAX_MEMORY_MB=256

# API rate limiting — shared across all replicas via Redis
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=600

# How long the API waits for a worker to pick up and complete a job
# before returning 504 to the client.
# Set higher if workers are slow to start (e.g. after a restart).
JOB_WAIT_TIMEOUT_MS=90000
