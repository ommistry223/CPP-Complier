
PORT=5000
NODE_ENV=development
JWT_SECRET=coderunner_dev_secret_2024_change_me
JWT_EXPIRES_IN=7d

DB_HOST=localhost
DB_PORT=5432
DB_NAME=coderunner
DB_USER=postgres
DB_PASSWORD=postgres

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Worker concurrency: 4 per replica × 12 replicas = 48 simultaneous compile jobs
WORKER_CONCURRENCY=8

# Execution limits
MAX_EXECUTION_TIME=10000
MAX_MEMORY_MB=256
MAX_CPU_TIME=5000
DOCKER_ENABLED=false
EXECUTION_TIMEOUT=10000

# API rate limiting — shared across all replicas via Redis
# 300 requests per minute per IP (up from 100)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=600

# How long the API waits for job.finished() before returning 504
JOB_WAIT_TIMEOUT_MS=90000
